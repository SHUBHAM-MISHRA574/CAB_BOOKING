# Server
PORT=5000

# MongoDB - replace with your connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/cabbooking

# JWT secret - change this to a random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this

# Allowed frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Optional: User-Agent for Nominatim/OSRM (required by Nominatim usage policy). Include app name and contact.
# NOMINATIM_USER_AGENT=CabBook/1.0 (your@email.com)
# Optional: timeout in ms for location/distance API calls (default 10000)
# LOCATION_FETCH_TIMEOUT_MS=10000
